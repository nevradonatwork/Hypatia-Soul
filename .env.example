# Copy this file to .env and fill in your real values. .env is git-ignored.

# Server Properties dialogunda gordugun sunucu adi (Server: NevraDonat\SQLEXPRESS)
TT_DB_SERVER=NevraDonat\SQLEXPRESS
TT_DB_NAME=TriggerTracker

# "windows" -> SSMS'te gordugun NEVRADONAT\nevra ile Windows Authentication
# "sql"     -> ayri bir SQL login (asagidaki TT_DB_USER/TT_DB_PASSWORD gerekir)
TT_DB_AUTH=windows

# Sadece TT_DB_AUTH=sql iken gerekli:
# TT_DB_USER=
# TT_DB_PASSWORD=

# Genelde degistirmene gerek yok:
# TT_DB_DRIVER=ODBC Driver 17 for SQL Server

FLASK_SECRET_KEY=dev-only-change-me
